<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Agentic_Browser.BrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Agentic_Browser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Shared resources -->
    <UserControl.Resources>

        <!-- Style for navigation icon buttons (back/forward/reload/etc) -->
        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}">

                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Padding="{TemplateBinding Padding}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RootGrid"
                                                            Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RootGrid"
                                                            Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                            To="#F4F2EF" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RootGrid"
                                                            Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                            To="#D0D0D0" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.7" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RootGrid"
                                                            Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.3" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Main layout -->
    <Grid Background="#F4F2EF">

        <!-- Outer rounded frame -->
        <Border Margin="4"
                CornerRadius="7"
                BorderBrush="#D6D3CE"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="43"/>
                    <!-- Top bar -->
                    <RowDefinition Height="*"/>
                    <!-- Web content + assistant -->
                </Grid.RowDefinitions>

                <!-- Top navigation bar -->
                <Grid Background="#fdfcf9"
                      BorderBrush="#D6D3CE"
                      BorderThickness="0,0,0,1"
                      Padding="6"
                      ColumnSpacing="6">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Nav buttons -->
                        <ColumnDefinition Width="*"/>
                        <!-- URL bar -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Right controls -->
                    </Grid.ColumnDefinitions>

                    <!-- Back / Forward / Reload -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="0">

                        <Button x:Name="BackButton"
                                Style="{StaticResource NavIconButtonStyle}"
                                IsEnabled="False">
                            <Image Source="/Assets/Icons/angle-small-left.svg"
                                   Width="15" Height="15"/>
                        </Button>

                        <Button x:Name="ForwardButton"
                                Style="{StaticResource NavIconButtonStyle}"
                                IsEnabled="False">
                            <Image Source="/Assets/Icons/angle-small-right.svg"
                                   Width="15" Height="15"/>
                        </Button>

                        <Button x:Name="ReloadButton"
                                Style="{StaticResource NavIconButtonStyle}">
                            <Grid>
                                <Image x:Name="ReloadIcon"
                                       Source="/Assets/Icons/rotate-right.svg"
                                       Width="11" Height="11"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <RotateTransform x:Name="ReloadRotate"/>
                                    </Image.RenderTransform>
                                    <Image.Resources>
                                        <Storyboard x:Name="ReloadAnimation">
                                            <DoubleAnimation Storyboard.TargetName="ReloadRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360"
                                                             Duration="0:0:1"
                                                             RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </Image.Resources>
                                </Image>

                                <Image x:Name="StopIcon"
                                       Source="/Assets/Icons/cross.svg"
                                       Width="10" Height="10"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                    </StackPanel>

                    <!-- URL / Address bar -->
                    <Grid x:Name="UrlBarContainer"
                          Grid.Column="1"
                          Background="#fdfcf9"
                          BorderBrush="#fdfcf9"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="6,0"
                          Margin="0,-2,0,-2"
                          PointerEntered="UrlBarContainer_PointerEntered"
                          PointerExited="UrlBarContainer_PointerExited">

                        <Grid ColumnSpacing="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Favicon -->
                                <ColumnDefinition Width="*"/>
                                <!-- TextBox -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Action icons -->
                            </Grid.ColumnDefinitions>

                            <Image x:Name="FaviconImage"
                                   Stretch="UniformToFill"
                                   Width="16" Height="16"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>

                            <TextBox x:Name="UrlBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     PlaceholderText=""
                                     IsSpellCheckEnabled="False"
                                     FocusVisualMargin="0"
                                     UseSystemFocusVisuals="False"
                                     FontFamily="ms-appx:///Assets/Fonts/substance-lightitalic.otf#FSP DEMO - Substance Light">
                                <TextBox.Resources>
                                    <!-- Kill the white inner background in every state -->
                                    <SolidColorBrush x:Key="TextControlBackground"              Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver"   Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused"       Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundDisabled"      Color="Transparent"/>
                                    <!-- Kill the teal / accent focus border -->
                                    <SolidColorBrush x:Key="TextControlBorderBrush"             Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"  Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused"      Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled"     Color="Transparent"/>
                                </TextBox.Resources>
                            </TextBox>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center">

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/bookmark.svg" Width="14" Height="14"/>
                                </Button>

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/chain.svg" Width="14" Height="14"/>
                                </Button>

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/equalizer.svg" Width="14" Height="14"/>
                                </Button>

                            </StackPanel>
                        </Grid>

                    </Grid>

                    <!-- Right-side controls (Download, Assistant, Profile, Menu) -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        
                        <Border Width="1" Height="18"
                                Background="#D6D3CE"
                                VerticalAlignment="Center"/>

                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Padding="4"
                                Click="ToggleDownloadButton_Click">
                            <Image Source="/Assets/Icons/download.svg" Width="14" Height="14"/>
                        </Button>

                        <Border Width="1" Height="18"
                                Background="#D6D3CE"
                                VerticalAlignment="Center"/>

                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Width="Auto"
                                Padding="6,2"
                                FontFamily="Funnel Sans"
                                Click="AssistantButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <!-- <Image Source="/Assets/Icons/icons8-ai.svg" Width="14" Height="14"/> -->
                                <TextBlock Text="Assistant"
                                           Foreground="#20808d"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Width="1" Height="18"
                                Background="#D6D3CE"
                                VerticalAlignment="Center"/>

                        <Button Style="{StaticResource NavIconButtonStyle}"
                                Width="Auto"
                                Padding="6,2"
                                FontFamily="Funnel Sans">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Image Source="/Assets/Icons/profile.svg" Width="14" Height="14"/>
                                <TextBlock Text="Profile"
                                           Foreground="Black"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Content="⋮" Width="30">
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuFlyoutItem Text="Search tabs" Icon="Find">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="A" Modifiers="Control,Shift"/>
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="New tab" Icon="Add">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="T" Modifiers="Control"/>
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Hariom Jangra (Signed in)">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph=""/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Extensions" Icon="OutlineStar"/>
                                    <MenuFlyoutItem Text="Settings" Click="Settings_Click">
                                        <MenuFlyoutItem.Icon>
                                            <SymbolIcon Symbol="Setting"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutSubItem Text="More tools" Icon="Repair">
                                        <MenuFlyoutItem Text="Task Manager"/>
                                        <MenuFlyoutItem Text="Developer Tools"/>
                                    </MenuFlyoutSubItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                    </StackPanel>

                </Grid>

                <!-- Web content + Assistant panel area -->
                <Grid Grid.Row="1" Background="#fdfcf9">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="WebColumn" Width="*"/>
                        <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                        <ColumnDefinition x:Name="AssistantColumn" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main browser content -->
                    <WebView2 x:Name="WebView"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                    <!-- Vertical splitter (shown when assistant is open) -->
                    <Border x:Name="GridSplitterBorder"
                            Grid.Column="1"
                            Width="5"
                            Background="Transparent"
                            Visibility="Collapsed">
                        <Rectangle Fill="#D6D3CE"
                                   Width="1"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Assistant side panel -->
                    <Grid x:Name="AssistantPanel"
                          Grid.Column="2"
                          Background="#F8F6F2">
                        <Border BorderBrush="#D6D3CE"
                                BorderThickness="1,0,0,0">
                            <WebView2 x:Name="AssistantWebView"
                                      Source="http://localhost:5050/"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>
                        </Border>
                    </Grid>

                </Grid>

            </Grid>
        </Border>
    </Grid>

</UserControl>