<?xml version="1.0" encoding="utf-8"?>

<!-- Browser View UserControl -->
<UserControl
    x:Class="Agentic_Browser.BrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Agentic_Browser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Shared resources used inside this control -->
    <UserControl.Resources>

        <!-- Style used for navigation icon buttons -->
        <Style x:Key="NavIconButtonStyle" TargetType="Button">

            <!-- Size -->
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>

            <!-- Shape -->
            <Setter Property="CornerRadius" Value="6"/>

            <!-- Default appearance -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>

            <!-- Custom button template -->
            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <!-- Root container for button visuals -->
                        <Grid
                            x:Name="RootGrid"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">

                            <!-- Button content -->
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="{TemplateBinding Padding}"/>

                            <!-- Visual states for interaction -->
                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <!-- Default state -->
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RootGrid"
                                                Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0:0:0.1"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>

                                    <!-- Hover state -->
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RootGrid"
                                                Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                To="#E5E5E5"
                                                Duration="0:0:0.1"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>

                                    <!-- Pressed state -->
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RootGrid"
                                                Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                To="#D0D0D0"
                                                Duration="0:0:0.05"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.7"
                                                Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>

                                    <!-- Disabled state -->
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RootGrid"
                                                Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0:0:0.1"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.3"
                                                Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                        </Grid>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>



    <!-- Main layout container -->
    <Grid Background="#F4F2EF">

        <!-- Outer browser frame -->
        <Border
            Margin="4"
            CornerRadius="7"
            BorderBrush="#D6D3CE"
            BorderThickness="1">

            <Grid>

                <!-- Layout rows -->
                <Grid.RowDefinitions>
                    <!-- Top navigation bar -->
                    <RowDefinition Height="43"/>
                    <!-- Web content area -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <!-- Top navigation bar -->
                <Grid
                    Background="#fdfcf9"
                    BorderBrush="#D6D3CE"
                    BorderThickness="0,0,0,1"
                    Padding="6"
                    ColumnSpacing="6">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>



                    <!-- Navigation buttons -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="0">

                        <!-- Back -->
                        <Button
                            x:Name="BackButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            IsEnabled="False">
                            <Image
                                Source="/Assets/Icons/angle-small-left.svg"
                                Width="15"
                                Height="15"/>
                        </Button>

                        <!-- Forward -->
                        <Button
                            x:Name="ForwardButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            IsEnabled="False">
                            <Image
                                Source="/Assets/Icons/angle-small-right.svg"
                                Width="15"
                                Height="15"/>
                        </Button>

                        <!-- Reload / Stop -->
                        <Button x:Name="ReloadButton" Style="{StaticResource NavIconButtonStyle}">

                            <Grid>

                                <!-- Reload icon with rotation animation -->
                                <Image
                                    x:Name="ReloadIcon"
                                    Source="/Assets/Icons/rotate-right.svg"
                                    Width="11"
                                    Height="11"
                                    RenderTransformOrigin="0.5,0.5">

                                    <Image.RenderTransform>
                                        <RotateTransform x:Name="ReloadRotate"/>
                                    </Image.RenderTransform>

                                    <!-- Reload animation -->
                                    <Image.Resources>
                                        <Storyboard x:Name="ReloadAnimation">
                                            <DoubleAnimation
                                                Storyboard.TargetName="ReloadRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0"
                                                To="360"
                                                Duration="0:0:1"
                                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </Image.Resources>

                                </Image>

                                <!-- Stop icon shown during loading -->
                                <Image
                                    x:Name="StopIcon"
                                    Source="/Assets/Icons/cross.svg"
                                    Width="10"
                                    Height="10"
                                    Visibility="Collapsed"/>

                            </Grid>

                        </Button>

                    </StackPanel>



                    <!-- URL bar -->
                    <Grid
                        x:Name="UrlBarContainer"
                        Grid.Column="1"
                        Background="#fdfcf9"
                        BorderBrush="#fdfcf9"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="5">

                        <Grid ColumnSpacing="1">

                            <Grid.ColumnDefinitions>
                                <!-- Favicon -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- URL textbox -->
                                <ColumnDefinition Width="*"/>
                                <!-- action icons -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>



                            <!-- Website favicon -->
                            <Image
                                x:Name="FaviconImage"
                                Stretch="UniformToFill"
                                Width="16"
                                Height="16"
                                VerticalAlignment="Center"/>



                            <!-- Address bar -->
                            <TextBox
                                x:Name="UrlBox"
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                PlaceholderText=""
                                IsSpellCheckEnabled="False"
                                FocusVisualMargin="0"
                                UseSystemFocusVisuals="False"
                                FontFamily="ms-appx:///Assets/Fonts/substance-lightitalic.otf#FSP DEMO - Substance Light"/>
                            <StackPanel
    Grid.Column="2"
    Orientation="Horizontal"
    Spacing="4"
    VerticalAlignment="Center">

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/bookmark.svg" Width="14" Height="14"/>
                                </Button>

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/chain.svg" Width="14" Height="14"/>
                                </Button>

                                <Button Style="{StaticResource NavIconButtonStyle}">
                                    <Image Source="/Assets/Icons/equalizer.svg" Width="14" Height="14"/>
                                    
                                </Button>

                                

                            </StackPanel>


                        </Grid>

                    </Grid>



                    <!-- Right side controls -->
                    <StackPanel
    Grid.Column="2"
    Orientation="Horizontal"
    Spacing="8"
    VerticalAlignment="Center">

                        <!-- Download button -->
                        <Button
        Background="Transparent"
        BorderThickness="0"
        Padding="4"
        FontFamily="Inter"
                            Click="ToggleDownloadButton_Click">

                            <Image
            Source="/Assets/Icons/download.svg"
            Width="14"
            Height="14"/>
                        </Button>



                        <!-- Assistant button -->
                        <Button
        Background="Transparent"
        BorderThickness="0"
        Padding="6,2"
        FontFamily="Inter"
        Click="AssistantButton_Click">

                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <Image
                Source="/Assets/Icons/icons8-ai.svg"
                Width="14"
                Height="14"/>

                                <TextBlock
                Text="Assistant"
                Foreground="#20808d"
                VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>



                        <!-- Separator -->
                        <Border
        Width="1"
        Height="18"
        Background="#D6D3CE"
        VerticalAlignment="Center"/>



                        <!-- User Profile -->
                        <Button
        Background="Transparent"
        BorderThickness="0"
        Padding="6,2"
        FontFamily="Inter">

                            <StackPanel Orientation="Horizontal" Spacing="5">

                                <Image
                Source="/Assets/Icons/profile.svg"
                Width="14"
                Height="14"/>

                                <TextBlock
                Text="User Name"
                Foreground="#20808d"
                VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>


                        <!-- Menu button -->
                        <Button Content="⋮" Width="30">

                            <Button.Flyout>

                                <MenuFlyout Placement="BottomEdgeAlignedRight">

                                    <MenuFlyoutItem Text="Search tabs" Icon="Find">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="A" Modifiers="Control,Shift"/>
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutItem Text="New tab" Icon="Add">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="T" Modifiers="Control"/>
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutSeparator/>

                                    <!-- Signed in user -->
                                    <MenuFlyoutItem Text="Hariom Jangra (Signed in)">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE77B;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutSeparator/>

                                    <MenuFlyoutItem Text="Extensions" Icon="OutlineStar"/>

                                    <!-- Settings -->
                                    <MenuFlyoutItem Text="Settings" Click="Settings_Click">
                                        <MenuFlyoutItem.Icon>
                                            <SymbolIcon Symbol="Setting"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutSeparator/>

                                    <!-- Developer tools -->
                                    <MenuFlyoutSubItem Text="More tools" Icon="Repair">
                                        <MenuFlyoutItem Text="Task Manager"/>
                                        <MenuFlyoutItem Text="Developer Tools"/>
                                    </MenuFlyoutSubItem>

                                </MenuFlyout>

                            </Button.Flyout>

                        </Button>

                    </StackPanel>

                </Grid>



                <!-- Main browser area -->
                <Grid Grid.Row="1" Background="#fdfcf9">

                    <Grid.ColumnDefinitions>
                        <!-- Main web content -->
                        <ColumnDefinition x:Name="WebColumn" Width="*"/>
                        <!-- Splitter -->
                        <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                        <!-- Assistant panel -->
                        <ColumnDefinition x:Name="AssistantColumn" Width="0"/>
                    </Grid.ColumnDefinitions>



                    <!-- Primary WebView -->
                    <WebView2
                        x:Name="WebView"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>



                    <!-- Splitter line -->
                    <Border
                        x:Name="GridSplitterBorder"
                        Grid.Column="1"
                        Width="5"
                        Background="Transparent"
                        Visibility="Collapsed">

                        <Rectangle
                            Fill="#D6D3CE"
                            Width="1"
                            HorizontalAlignment="Center"/>

                    </Border>



                    <!-- Assistant side panel -->
                    <Grid
                        x:Name="AssistantPanel"
                        Grid.Column="2"
                        Background="#F8F6F2">

                        <Border
                            BorderBrush="#D6D3CE"
                            BorderThickness="1,0,0,0">

                            <WebView2
                                x:Name="AssistantWebView"
                                Source="http://localhost:5050/"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>

                        </Border>

                    </Grid>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</UserControl>