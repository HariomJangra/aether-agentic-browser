<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Agentic_Browser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Agentic_Browser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Agentic Browser">

    <Grid Background="#d3e3fd">
        <TabView x:Name="Tabs"
         FontFamily="Raleway"
         Background="#f4f2ef"
         VerticalAlignment="Stretch"
         AddTabButtonClick="TabView_AddTabButtonClick"
         TabCloseRequested="TabView_TabCloseRequested"
         CanReorderTabs="True"
         CanDragTabs="True">

            <TabView.Resources>
                <SolidColorBrush x:Key="TabViewTrackBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="TabViewBorderBrush" Color="Transparent" />
                <Thickness x:Key="TabViewHeaderPadding">0,2,0,0</Thickness>

                <Style TargetType="TabViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabViewItem">
                                <Grid Margin="2,2,2,0" Background="Transparent" MinHeight="34">

                                    <Popup x:Name="HoverCardPopup" VerticalOffset="42" Opened="HoverCardPopup_Opened">
                                        <Popup.ChildTransitions>
                                            <TransitionCollection>
                                                <EntranceThemeTransition FromVerticalOffset="-8" />
                                            </TransitionCollection>
                                        </Popup.ChildTransitions>

                                        <Grid Width="260" Background="#fffefb" BorderBrush="#D2D2D2" BorderThickness="1" CornerRadius="8" Padding="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{TemplateBinding Header}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" Foreground="Black"/>

                                            <TextBlock Grid.Row="1" Text="{TemplateBinding Tag}" FontSize="12" Foreground="#555555" Margin="0,2,0,10" TextTrimming="CharacterEllipsis" />

                                            <Border x:Name="PreviewBorder" Grid.Row="2" Height="120" Background="#f4f2ef" CornerRadius="4" BorderBrush="#D2D2D2" BorderThickness="1">
                                                <Image Stretch="UniformToFill" />
                                            </Border>
                                        </Grid>
                                    </Popup>

                                    <Border x:Name="PillBorder" 
                                            Background="Transparent"
                                            CornerRadius="8" 
                                            BorderThickness="1"
                                            BorderBrush="Transparent">

                                        <Grid Padding="10,0,4,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <IconSourceElement x:Name="IconControl"
                                                               IconSource="{TemplateBinding IconSource}"
                                                               VerticalAlignment="Center" 
                                                               Margin="0,0,8,0"
                                                               Width="16" Height="16"/>

                                            <ContentPresenter x:Name="HeaderPresenter"
                                                              Grid.Column="1"
                                                              Content="{TemplateBinding Header}"
                                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Stretch"
                                                              FontSize="12" />

                                            <Button x:Name="CloseButton"
                                                    Grid.Column="2"
                                                    Margin="4,0,0,0"
                                                    Width="28" Height="28"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="4">
                                                <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="10" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">

                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="Transparent" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="Transparent" />
                                                    <Setter Target="HoverCardPopup.IsOpen" Value="False" />
                                                </VisualState.Setters>
                                            </VisualState>

                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverCardPopup" Storyboard.TargetProperty="IsOpen">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.4">
                                                            <DiscreteObjectKeyFrame.Value>
                                                                <x:Boolean>True</x:Boolean>
                                                            </DiscreteObjectKeyFrame.Value>
                                                        </DiscreteObjectKeyFrame>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="#E0E8F5" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="Transparent" />
                                                    <Setter Target="PreviewBorder.Visibility" Value="Visible" />
                                                </VisualState.Setters>
                                            </VisualState>

                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="#D0D8E5" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="Transparent" />
                                                    <Setter Target="HoverCardPopup.IsOpen" Value="False" />
                                                </VisualState.Setters>
                                            </VisualState>

                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="#fffefb" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="#D2D2D2" />
                                                    <Setter Target="HoverCardPopup.IsOpen" Value="False" />
                                                </VisualState.Setters>
                                            </VisualState>

                                            <VisualState x:Name="PointerOverSelected">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverCardPopup" Storyboard.TargetProperty="IsOpen">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.4">
                                                            <DiscreteObjectKeyFrame.Value>
                                                                <x:Boolean>True</x:Boolean>
                                                            </DiscreteObjectKeyFrame.Value>
                                                        </DiscreteObjectKeyFrame>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="#fffefb" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="#D2D2D2" />
                                                    <Setter Target="PreviewBorder.Visibility" Value="Collapsed" />
                                                </VisualState.Setters>
                                            </VisualState>

                                            <VisualState x:Name="PressedSelected">
                                                <VisualState.Setters>
                                                    <Setter Target="PillBorder.Background" Value="#fffefb" />
                                                    <Setter Target="PillBorder.BorderBrush" Value="#D2D2D2" />
                                                    <Setter Target="HoverCardPopup.IsOpen" Value="False" />
                                                </VisualState.Setters>
                                            </VisualState>

                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabView.Resources>

            <TabView.TabStripFooter>
                <Grid x:Name="DragRegion" Background="Transparent" MinWidth="180"/>
            </TabView.TabStripFooter>
        </TabView>
    </Grid>
</Window>